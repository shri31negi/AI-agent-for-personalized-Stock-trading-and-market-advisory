# TradeMind AI Frontend Environment Variables

# API Configuration (for future backend integration)
# VITE_API_URL=http://localhost:3000/api
# VITE_API_KEY=your_api_key_here

# Feature Flags
# VITE_ENABLE_LIVE_TRADING=false
# VITE_ENABLE_REAL_TIME_DATA=false

# Analytics (optional)
# VITE_ANALYTICS_ID=your_analytics_id

# Third-party Services (optional)
# VITE_MARKET_DATA_API_KEY=your_market_data_key
# VITE_NEWS_API_KEY=your_news_api_key

# Note: Currently the app uses mock data and doesn't require any environment variables
# Copy this file to .env when you need to configure real API connections
